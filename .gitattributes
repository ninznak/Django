# Normalize line endings; Git decides binary vs text.
* text=auto

# Never apply line-ending conversion to binaries / local DB.
*.sqlite3 binary
*.db binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
*.zip binary

# Source and config: LF in repo and working tree (avoids CRLF/LF churn on Windows).
*.py text eol=lf
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.sh text eol=lf
.env.example text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
