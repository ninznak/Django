# Пример файла для /etc/cron.d/creativesphere-update (имя файла произвольное).
#
# 1. Скопируйте содержимое ниже в новый файл, например:
#    sudo nano /etc/cron.d/creativesphere-update
# 2. Замените /var/www/Django на реальный путь к проекту на VPS.
# 3. При ветке не main используйте строку с env (см. комментарий).
# 4. Права: chmod 644 /etc/cron.d/creativesphere-update
#
# Логи: основной — deploy/update.log внутри проекта; дополнительно — deploy/cron.log

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Каждый день в 03:15 (время и путь поправьте под себя).
# update-safe.sh: сначала бэкап БД (pg_dump или копия SQLite) + JSON-снапшот
# статей, затем обычный update.sh. Контент, добавленный через админку,
# не потеряется даже при неудачной миграции.
15 3 * * * root /bin/bash /var/www/Django/scripts/update-safe.sh /var/www/Django >> /var/www/Django/deploy/cron.log 2>&1

# Альтернатива без бэкапа (НЕ рекомендуется, если контент правится в админке):
# 15 3 * * * root /bin/bash /var/www/Django/scripts/update.sh /var/www/Django >> /var/www/Django/deploy/cron.log 2>&1

# Альтернатива с явной веткой и именем службы Gunicorn:
# 15 3 * * * root env GIT_BRANCH=main GUNICORN_SERVICE=creativesphere-gunicorn /bin/bash /var/www/Django/scripts/update-safe.sh /var/www/Django >> /var/www/Django/deploy/cron.log 2>&1

# SSL: основное авто-продление делает системный certbot.timer. Строка ниже —
# страховка на случай его отключения (раз в неделю, пн 04:20; безопасно:
# certbot renew трогает только сертификаты с < 30 днями до истечения):
# 20 4 * * 1 root /bin/bash /var/www/Django/scripts/ssl-renew.sh /var/www/Django >> /var/www/Django/deploy/cron.log 2>&1
