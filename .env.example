# Copy to .env on the server. Never commit .env with real secrets.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=0

# All apex domains this Django app answers (HTTPS). Default in code when unset
# (production): kurilenkoart.ru — override here to add more apices.
DJANGO_SITE_DOMAINS=kurilenkoart.ru

# Host used for canonical URLs, sitemap, Open Graph (one primary brand URL).
DJANGO_CANONICAL_DOMAIN=kurilenkoart.ru
PUBLIC_SITE_URL=https://kurilenkoart.ru

# --- База данных ---
# Вариант A — PostgreSQL на VPS (база вне git, не мешает pull). Установите пакет из requirements.txt.
# DJANGO_DATABASE=postgresql
# POSTGRES_DB=creativesphere
# POSTGRES_USER=creativesphere
# POSTGRES_PASSWORD=сгенерируйте-надёжный-пароль
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_CONN_MAX_AGE=60

# Вариант B — SQLite (по умолчанию). Абсолютный путь *вне* git, если не хотите db.sqlite3 в каталоге проекта:
# DJANGO_SQLITE_PATH=/var/lib/creativesphere/db.sqlite3
# DJANGO_SQLITE_PATH=

# Optional: full overrides (leave empty to derive from DJANGO_SITE_DOMAINS)
# ALLOWED_HOSTS=kurilenkoart.ru,www.kurilenkoart.ru
# CSRF_TRUSTED_ORIGINS=https://kurilenkoart.ru,https://www.kurilenkoart.ru

# Optional HTTPS tuning (production):
# SECURE_SSL_REDIRECT=1
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=1
# SECURE_HSTS_PRELOAD=0

# Public contact address (footer, JSON-LD, default From if unset)
SEO_CONTACT_EMAIL=me@nobito.ru

# Outbound email: DEBUG=1 defaults to console backend (no SMTP required).
# Production: set SMTP (works with SendGrid, Mailgun, Amazon SES SMTP, etc.)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_USE_SSL=0
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=me@nobito.ru
# Optional: inbox for contact form (defaults to SEO_CONTACT_EMAIL)
# CONTACT_FORM_RECIPIENT=me@nobito.ru
# Save messages in Django admin only; skip notification email attempt:
# CONTACT_FORM_TRY_EMAIL=0

# Abuse protection (cache-backed throttling + checkout idempotency retention).
# Keep defaults unless you have a reason to tune:
# CONTACT_FORM_POST_LIMIT=5
# CONTACT_FORM_WINDOW_SECONDS=600
# AUTH_POST_LIMIT=20
# AUTH_WINDOW_SECONDS=300
# CART_API_POST_LIMIT=120
# CART_API_WINDOW_SECONDS=60
# CHECKOUT_POST_LIMIT=8
# CHECKOUT_WINDOW_SECONDS=600
# CHECKOUT_IDEMPOTENCY_TTL_SECONDS=86400
# CHECKOUT_IDEMPOTENCY_SESSION_KEY=checkout_idempotency_key

# Show "Sign up" + registration form on /sign-up-login/ (default off).
# AUTH_SHOW_REGISTRATION=1

# Analytics (optional). Defaults for KurilenkoArt are set in creativesphere/settings.py; override here.
# Yandex.Metrica: https://metrica.yandex.com/ — site counter 103952385.
# Top.Mail.Ru: https://top.mail.ru/
# To disable Metrika locally: YANDEX_METRIKA_ID=
# YANDEX_METRIKA_ID=103952385
# MAILRU_TOP_ID=
