# Copy to .env on the server. Never commit .env with real secrets.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=0

# All apex domains this Django app answers (HTTPS). Default in code when unset (production):
# trally.ru,kurilenkoart.ru — override here if needed.
DJANGO_SITE_DOMAINS=trally.ru,kurilenkoart.ru

# Host used for canonical URLs, sitemap, Open Graph (one primary brand URL).
DJANGO_CANONICAL_DOMAIN=trally.ru
PUBLIC_SITE_URL=https://trally.ru

# When moving the main site to kurilenkoart.ru, switch to e.g.:
# DJANGO_CANONICAL_DOMAIN=kurilenkoart.ru
# PUBLIC_SITE_URL=https://kurilenkoart.ru

# Optional: full overrides (leave empty to derive from DJANGO_SITE_DOMAINS)
# ALLOWED_HOSTS=trally.ru,www.trally.ru,kurilenkoart.ru,www.kurilenkoart.ru
# CSRF_TRUSTED_ORIGINS=https://trally.ru,https://www.trally.ru,https://kurilenkoart.ru,https://www.kurilenkoart.ru

# Optional HTTPS tuning (production):
# SECURE_SSL_REDIRECT=1
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=1
# SECURE_HSTS_PRELOAD=0

# Public contact address (footer, JSON-LD, default From if unset)
SEO_CONTACT_EMAIL=me@nobito.ru

# Outbound email: DEBUG=1 defaults to console backend (no SMTP required).
# Production: set SMTP (works with SendGrid, Mailgun, Amazon SES SMTP, etc.)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_USE_SSL=0
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=me@nobito.ru
# Optional: inbox for contact form (defaults to SEO_CONTACT_EMAIL)
# CONTACT_FORM_RECIPIENT=me@nobito.ru
# Save messages in Django admin only; skip notification email attempt:
# CONTACT_FORM_TRY_EMAIL=0
